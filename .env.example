# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit real secrets.

# Required
DATABASE_URL=postgres://starter:starter@localhost:5432/starter?sslmode=disable

# Optional — reader replica (defaults to DATABASE_URL if not set)
# DATABASE_READ_URL=postgres://starter:starter@localhost:5432/starter?sslmode=disable

# Optional (shown with defaults)
PORT=8080
